---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechSwapper from '../components/TechSwapper.astro';
import LandingPageCard from '../components/LandingPageCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero-section {
				margin-bottom: 3rem;
			}
			.welcome-text {
				font-size: 1.25rem;
				line-height: 1.75;
				color: rgb(var(--gray-dark));
			}
			.illustration-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				margin-top: 3rem;
				padding: 2rem;
				border-radius: 16px;
				position: relative;
				border: 1px solid rgba(var(--gray-light), 0.5);
				background: rgba(var(--gray-light), 0.1);
			}
			:root.dark .illustration-container {
				border-color: rgba(var(--gray-dark), 0.3);
				background: rgba(var(--gray-dark), 0.1);
			}
			.location-illustration {
				max-width: 100%;
				height: auto;
				max-height: 450px;
				object-fit: contain;
			}
			.credit {
				margin-top: 1.5rem;
				font-size: 0.875rem;
				color: rgb(var(--gray));
				text-align: center;
			}
			.credit a {
				color: inherit;
				text-decoration: underline;
			}
			.map-overlay {
				position: absolute;
				bottom: 1.5rem;
				right: 1.5rem;
				background: rgba(255, 255, 255, 0.9);
				padding: 0.5rem 1rem;
				border-radius: 9999px;
				font-weight: 600;
				font-size: 0.875rem;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
				pointer-events: none;
				backdrop-filter: blur(4px);
				color: #000;
			}
			:root.dark .map-overlay {
				background: rgba(18, 22, 31, 0.9);
				color: #fff;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section pt-20 md:-mx-12 lg:-mx-24">
				<h1 class="text-7xl md:text-8xl font-black mb-12 tracking-tighter leading-[0.9]">
					Hej, I'm Frederik.
				</h1>
				<div class="welcome-text max-w-5xl space-y-12">
					<p class="text-3xl md:text-4xl leading-snug text-gray-700 dark:text-gray-500">
						I'm a <strong class="text-black dark:text-white font-black">software engineer</strong> based in <strong class="text-black dark:text-white font-black">Copenhagen, Denmark</strong>. 
					</p>
					<p class="text-2xl md:text-3xl leading-loose text-gray-600 dark:text-gray-500">
						I'm passionate about building software that makes a <strong class="text-black dark:text-white font-bold">difference</strong> and love to explore <TechSwapper /> while doing so.
					</p>
				</div>

			</section>

			<LandingPageCard 
				title="It's that deep!" 
				expansion='not'
				description="I'm working on several projects around Denmark and love to travel for work when it makes sense. I'm always open for new opportunities!"
				flipper={false}
			/>
			<LandingPageCard 
				title="What's cup?" 
				expansion="in my"
				description="While based in Copenhagen, my work extends globally. I collaborate with clients and teams worldwide, ensuring that distance is never a barrier to delivering exceptional results."
				flipper={true}
			/>
		</main>
		<Footer />
	</body>
</html>
