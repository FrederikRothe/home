---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechSwapper from '../components/TechSwapper.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import locationImage from '../assets/icons/shop-and-geolocation-marker-store-locator-or-business-presence.svg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero-section {
				margin-bottom: 3rem;
			}
			.welcome-text {
				font-size: 1.25rem;
				line-height: 1.75;
				color: rgb(var(--gray-dark));
			}
			.illustration-container {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				margin-top: 3rem;
				padding: 2rem;
				border-radius: 16px;
				position: relative;
				border: 1px solid rgba(var(--gray-light), 0.5);
				background: rgba(var(--gray-light), 0.1);
			}
			:root.dark .illustration-container {
				border-color: rgba(var(--gray-dark), 0.3);
				background: rgba(var(--gray-dark), 0.1);
			}
			.location-illustration {
				max-width: 100%;
				height: auto;
				max-height: 450px;
				object-fit: contain;
			}
			.credit {
				margin-top: 1.5rem;
				font-size: 0.875rem;
				color: rgb(var(--gray));
				text-align: center;
			}
			.credit a {
				color: inherit;
				text-decoration: underline;
			}
			.map-overlay {
				position: absolute;
				bottom: 1.5rem;
				right: 1.5rem;
				background: rgba(255, 255, 255, 0.9);
				padding: 0.5rem 1rem;
				border-radius: 9999px;
				font-weight: 600;
				font-size: 0.875rem;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
				pointer-events: none;
				backdrop-filter: blur(4px);
				color: #000;
			}
			:root.dark .map-overlay {
				background: rgba(18, 22, 31, 0.9);
				color: #fff;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1 class="text-6xl font-black mb-6 tracking-tight">Hej, I'm Frederik.</h1>
				<div class="welcome-text space-y-4">
					<p class="leading-relaxed">
						I'm a <strong>software engineer</strong> based in <strong>Copenhagen, Denmark</strong>. <br> <br>
						&nbsp I'm passionate about building software that make a <strong>difference</strong> and love to dapple with <strong>cool</strong> technologies while doing so.
						<TechSwapper />
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
