---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TechSwapper from '../components/TechSwapper.astro';
import LandingPageCard from '../components/LandingPageCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import cloudIconUrl from '../assets/icons/cute-cloud-with-headband-meditating-mental-health-and-balance-calm-and-peace.json?url';
import coffeeIcon from '../assets/icons/handy-cup-of-coffee.svg';
import { getLatestCoffee } from '../lib/coffeeService';

const latestCoffee = await getLatestCoffee();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.content-wrapper {
				min-height: 110vh;
			}
			.hero-section {
				margin-bottom: 8rem;
			}
			.welcome-text {
				font-size: 1.25rem;
				line-height: 1.75;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<div class="content-wrapper">
			<Header />
			<main>
				<section class="hero-section pt-20 md:-mx-12 lg:-mx-24 ">
					<h1 class="text-7xl md:text-8xl font-black mb-12 tracking-tighter leading-[0.9]">
						Hej, I'm Frederik.
					</h1>
					<div class="welcome-text max-w-5xl space-y-12">
						<p class="text-3xl md:text-4xl leading-snug text-gray-400 dark:text-gray-500">
							I'm a <strong class="text-black dark:text-white font-black">software engineer</strong> based in <strong class="text-black dark:text-white font-black">Copenhagen, Denmark</strong>. 
						</p>
						<p class="text-2xl md:text-3xl leading-loose text-gray-400 dark:text-gray-500">
							I'm passionate about building software that makes a <strong class="text-black dark:text-white font-bold">difference</strong> and love to explore <TechSwapper /> while doing so.
						</p>
					</div>

				</section>
				<LandingPageCard 
					title="What's cup?" 
					expansion="in my"
					flipper={true}
					MyIcon={coffeeIcon}
				>
					<p class="text-2xl leading-relaxed text-[rgb(var(--gray-dark))]">
						I'm currently sipping on {latestCoffee ? (
							<>
								{latestCoffee.url ? (
									<a 
										href={latestCoffee.url} 
										target="_blank" 
										rel="noopener noreferrer"
										class="text-[rgb(var(--black))] font-bold underline decoration-2 underline-offset-4 hover:opacity-70 transition-opacity"
									>
										{latestCoffee.name}
									</a>
								) : (
									<span class="text-[rgb(var(--black))] font-bold underline decoration-2 underline-offset-4">
										{latestCoffee.name}
									</span>
								)} from {latestCoffee.roaster}
							</>
						) : (
							<span class="text-[rgb(var(--black))] font-bold underline decoration-2 underline-offset-4">some great coffee</span>
						)}. I'm always on the lookout for the next great cup, just check out <a href="/coffee" class="text-[rgb(var(--black))] font-bold underline decoration-2 underline-offset-4 hover:opacity-70 transition-opacity">my track record</a>!
					</p>
				</LandingPageCard>
			</main>
		</div>
		<Footer />
	</body>
</html>
