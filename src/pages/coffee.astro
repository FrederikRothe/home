---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getAllCoffees } from '../lib/coffeeService';
import CoffeeTable from '../components/CoffeeTable';
import CurrentCoffeeCard from '../components/CurrentCoffeeCard.astro';

const allCoffees = await getAllCoffees();
const latestCoffee = allCoffees[0] ?? null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Coffee Log | ${SITE_TITLE}`} description="A log of coffee beans I have tried over the years." />
		<style>
			.content-wrapper {
				min-height: 110vh;
			}
		</style>
	</head>
	<body>
		<div class="content-wrapper">
			<Header />
			<main class="max-w-5xl mx-auto px-4 md:px-0 py-12">
				<h1 class="text-5xl md:text-6xl font-black mb-8 tracking-tighter">
					Coffee
				</h1>
				<p class="text-xl text-[rgb(var(--gray))] mb-12">
					A personal log of the different coffee beans I've tried throughout the years.
				</p>

				{latestCoffee && (
					<section class="mb-16">
						<CurrentCoffeeCard coffee={latestCoffee} />
					</section>
				)}

				<section>
					<h2 class="text-3xl font-bold mb-6">Beans of the past</h2>
					{allCoffees.length > 0 ? (
						<CoffeeTable initialCoffees={allCoffees} client:load />
					) : (
						<p class="text-[rgb(var(--gray))]">No coffee logged yet.</p>
					)}
				</section>
			</main>
		</div>
		<Footer />
	</body>
</html>