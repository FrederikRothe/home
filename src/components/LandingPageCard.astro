---
import { Image } from 'astro:assets';
import myIcon from '../assets/icons/shop-and-geolocation-marker-store-locator-or-business-presence.svg';

interface Props {
	title?: string;
	description?: string;
	flipper?: boolean;
	expansion?: string;
}

const { 
  title = "Our Presence", 
  description = "We are strategically located to serve our customers better. Our presence ensures that you get the best service wherever you are.",
  flipper = false,
  expansion = ""
} = Astro.props;

// Split title to insert expansion
const titleWords = title.split(' ');
const firstWord = titleWords[0];
const restOfTitle = titleWords.slice(1).join(' ');
---

<div class={`landing-page-card group bg-transparent p-8 md:p-12 flex flex-col items-center gap-12 my-16 transition-all duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] opacity-70 grayscale-[30%] hover:opacity-100 hover:grayscale-0 md:-mx-12 lg:-mx-24 ${flipper ? 'md:flex-row-reverse' : 'md:flex-row'}`}>
  <div class={`flex-shrink-0 w-full md:w-2/5 max-w-[380px] transition-transform duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] ${flipper ? 'group-hover:translate-y-[-1rem] md:group-hover:translate-y-0 md:group-hover:translate-x-[2.5rem]' : 'group-hover:translate-y-[-1rem] md:group-hover:translate-y-0 md:group-hover:translate-x-[-2.5rem]'}`}>
    <Image src={myIcon} alt="Shop and Geolocation illustration" class="w-full h-auto" />
  </div>
  <div class={`flex-grow flex flex-col justify-center transition-transform duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] ${flipper ? 'group-hover:translate-y-[1rem] md:group-hover:translate-y-0 md:group-hover:translate-x-[-2.5rem]' : 'group-hover:translate-y-[1rem] md:group-hover:translate-y-0 md:group-hover:translate-x-[2.5rem]'}`}>
    <h2 class="text-5xl font-bold tracking-tight text-gray-800 dark:text-gray-200 transition-transform duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] group-hover:-translate-y-2 flex items-baseline">
      <span class="transition-transform duration-[800ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] group-hover:-translate-x-3">{firstWord}</span>
      {expansion ? (
        <span class="inline-block max-w-[0.3em] group-hover:max-w-[10em] transition-[max-width] duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] overflow-hidden">
          <span class="inline-block translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-[1000ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] delay-300 whitespace-nowrap">
            &nbsp;{expansion}&nbsp;
          </span>
        </span>
      ) : (
        <span class="transition-transform duration-[800ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] group-hover:scale-x-150">&nbsp;</span>
      )}
      <span class="transition-transform duration-[800ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] group-hover:translate-x-3">{restOfTitle}</span>
    </h2>
    <div class="max-h-0 opacity-0 overflow-hidden transition-all duration-[1200ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] group-hover:max-h-[500px] group-hover:opacity-100 group-hover:mt-6">
      <p class="text-2xl leading-relaxed text-gray-500 dark:text-gray-500">
        {description}
      </p>
      <slot />
    </div>
  </div>
</div>

<style>
  /* No default background styles to ensure it blends perfectly */
</style>
