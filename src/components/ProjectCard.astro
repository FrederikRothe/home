---
interface Props {
	title: string;
	description: string;
	tags?: string[];
	href?: string;
	github?: string;
}

const { title, description, tags = [], href, github } = Astro.props;
---

<div class="project-card rounded-2xl overflow-hidden p-8 md:p-10 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl group">
	<div class="space-y-6">
	<div class="flex justify-between items-center gap-8 md:gap-12">
		<h3 class="text-3xl md:text-4xl font-black tracking-tighter text-[rgb(var(--black))] leading-none">
		{href ? (
			<a href={href} target="_blank" rel="noopener noreferrer" class="hover:text-[rgb(var(--accent))] transition-colors">
			{title}
			</a>
		) : (
			title
		)}
		</h3>
		{github && (
		<a href={github} target="_blank" rel="noopener noreferrer" class="text-[rgb(var(--gray))] hover:text-[rgb(var(--black))] transition-transform duration-300 hover:scale-110 flex-shrink-0">
			<span class="sr-only">GitHub Repository</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28" fill="currentColor">
			<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
			</svg>
		</a>
		)}
	</div>

	<p class="text-xl text-[rgb(var(--gray-dark))] leading-relaxed max-w-4xl">
		{description}
	</p>

	{tags.length > 0 && (
		<div class="flex flex-wrap gap-2.5 pt-2">
			{tags.map((tag) => (
				<span key={tag} class="px-4 py-1.5 text-sm font-bold rounded-full bg-[rgb(var(--accent))]/5 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent))] border border-[rgb(var(--accent))]/10 transition-colors group-hover:bg-[rgb(var(--accent))]/10">
					{tag}
				</span>
			))}
		</div>
	)}	</div>
</div>

<style>
	.project-card {
	background: rgba(var(--gray-light), 0.2);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border: 1px solid rgba(var(--gray), 0.08);
	}

	:root.dark .project-card {
	background: rgba(var(--gray-light), 0.05);
	border: 1px solid rgba(var(--gray), 0.1);
	}
</style>
