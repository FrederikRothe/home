---
import type { Coffee } from '../types/coffee';
import FormattedDate from './FormattedDate.astro';

interface Props {
	coffee: Coffee;
}

const { coffee } = Astro.props;
---

<div class="glass-card relative overflow-hidden rounded-3xl p-8 md:p-12 shadow-2xl transition-all hover:shadow-[rgb(var(--accent))]/10 group">
    <!-- Decorative background elements -->
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-[rgb(var(--accent))] opacity-5 blur-3xl rounded-full group-hover:opacity-10 transition-opacity"></div>
    <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-[rgb(var(--gray))] opacity-5 blur-3xl rounded-full group-hover:opacity-10 transition-opacity"></div>

    <div class="relative z-10 space-y-8">
        <!-- Title Header -->
        <div class="space-y-2">
            <div class="flex items-center gap-3">
                <span class="px-3 py-1 bg-[rgb(var(--accent))] text-white text-[10px] font-bold uppercase tracking-widest rounded-full">
                    Currently Sipping
                </span>
                <span class="text-sm font-medium text-[rgb(var(--gray))]">
                    Started <FormattedDate date={coffee.dateTried} />
                </span>
            </div>
            <h3 class="text-5xl md:text-7xl font-black tracking-tighter text-[rgb(var(--black))] leading-tight">
                {coffee.name}
            </h3>
        </div>

        <!-- Grid Layout -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
            <!-- Left Column: Image -->
            <div class="md:col-span-5 lg:col-span-4">
                {coffee.imageUrl ? (
                    <div class="w-full aspect-square bg-white/80 dark:bg-black/20 backdrop-blur-sm rounded-2xl overflow-hidden shadow-inner border border-white/20 p-6 flex items-center justify-center group-hover:scale-[1.02] transition-transform duration-500">
                        <img 
                            src={coffee.imageUrl} 
                            alt={`Coffee bag for ${coffee.name}`}
                            class="max-w-full max-h-full object-contain drop-shadow-2xl"
                        />
                    </div>
                ) : (
                    <div class="w-full aspect-square bg-white/40 dark:bg-black/10 backdrop-blur-sm rounded-2xl border border-dashed border-white/30 flex items-center justify-center text-[rgb(var(--gray))] italic">
                        No image available
                    </div>
                )}
            </div>

            <!-- Right Column: Stats -->
            <div class="md:col-span-7 lg:col-span-8 space-y-8">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="space-y-6">
                        <div class="space-y-1">
                            <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--gray))]">Roaster</h4>
                            <p class="text-2xl font-bold text-[rgb(var(--gray-dark))]">
                                {coffee.url ? (
                                    <a href={coffee.url} target="_blank" rel="noopener noreferrer" class="text-[rgb(var(--accent))] hover:underline decoration-2 underline-offset-4">
                                        {coffee.roaster}
                                    </a>
                                ) : (
                                    <span>{coffee.roaster}</span>
                                )}
                            </p>
                        </div>

                        <div class="space-y-4">
                            <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--gray))]">Details</h4>
                            <div class="flex flex-wrap gap-3">
                                <div class="px-4 py-2 bg-white/40 dark:bg-black/20 border border-white/20 rounded-xl text-sm font-semibold flex items-center gap-2">
                                    <span class="text-[rgb(var(--gray))] uppercase text-[10px] tracking-wider">Origin</span>
                                    <span>{coffee.origin}</span>
                                </div>
                                <div class="px-4 py-2 bg-white/40 dark:bg-black/20 border border-white/20 rounded-xl text-sm font-semibold flex items-center gap-2">
                                    <span class="text-[rgb(var(--gray))] uppercase text-[10px] tracking-wider">Roast</span>
                                    <span>{coffee.roastLevel}</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="space-y-1">
                            <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--gray))]">Rating</h4>
                            <div class="flex items-baseline gap-1">
                                <span class="text-6xl font-black text-[rgb(var(--black))] tabular-nums">{coffee.rating}</span>
                                <span class="text-xl font-bold text-[rgb(var(--gray))]">/10</span>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-[rgb(var(--gray))]">Tasting Notes</h4>
                            <div class="flex flex-wrap gap-2">
                                {coffee.tastingNotes.map((note) => (
                                    <span class="px-3 py-1.5 bg-[rgba(var(--accent),8%)] border border-[rgba(var(--accent),15%)] text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent))] rounded-lg text-sm font-medium">
                                        {note}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-card {
        background: rgba(var(--gray-light), 0.3);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(var(--gray), 0.1);
    }
    
    :root.dark .glass-card {
        background: rgba(var(--gray-light), 0.1);
        border: 1px solid rgba(var(--gray), 0.1);
    }
</style>
