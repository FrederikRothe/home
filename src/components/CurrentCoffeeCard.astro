---
import type { Coffee } from '../types/coffee';

interface Props {
	coffee: Coffee;
}

const { coffee } = Astro.props;
---

<div class="coffee-card rounded-2xl overflow-hidden">
    <div class="flex gap-8 items-center p-8 md:p-10">
        <!-- Image -->
        {coffee.imageUrl ? (
            <div class="flex-shrink-0 w-28 h-28 md:w-36 md:h-36 rounded-xl overflow-hidden bg-white/60 dark:bg-white/5 flex items-center justify-center p-3">
                <img
                    src={coffee.imageUrl}
                    alt={coffee.name}
                    class="max-w-full max-h-full object-contain drop-shadow-md"
                />
            </div>
        ) : (
            <div class="flex-shrink-0 w-28 h-28 md:w-36 md:h-36 rounded-xl bg-white/30 dark:bg-white/5 border border-dashed border-[rgb(var(--gray))]/20 flex items-center justify-center text-4xl">
                ☕
            </div>
        )}

        <!-- Content -->
        <div class="min-w-0 space-y-3">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-[rgb(var(--accent))]">Currently Sipping</p>

            <div>
                <h3 class="text-2xl md:text-3xl font-black tracking-tight text-[rgb(var(--black))] leading-tight truncate">
                    {coffee.name}
                </h3>
                <p class="text-base text-[rgb(var(--gray))] mt-0.5">
                    {coffee.url ? (
                        <a
                            href={coffee.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-[rgb(var(--accent))] transition-colors"
                        >
                            {coffee.roaster}
                        </a>
                    ) : (
                        coffee.roaster
                    )}
                </p>
            </div>

            <!-- Tasting notes -->
            {coffee.tastingNotes.length > 0 && (
                <div class="flex flex-wrap gap-1.5 pt-1">
                    {coffee.tastingNotes.slice(0, 4).map((note) => (
                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-[rgb(var(--accent))]/8 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent))] border border-[rgb(var(--accent))]/15">
                            {note}
                        </span>
                    ))}
                </div>
            )}
        </div>

        <!-- Rating -->
        <div class="flex-shrink-0 hidden sm:flex flex-col items-center ml-auto pl-8 border-l border-[rgb(var(--gray))]/10">
            <span class="text-4xl font-black tabular-nums text-[rgb(var(--black))]">{coffee.rating}</span>
            <span class="text-xs text-[rgb(var(--gray))] mt-0.5">/10</span>
        </div>
    </div>
</div>

<style>
    .coffee-card {
        background: rgba(var(--gray-light), 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(var(--gray), 0.1);
    }

    :root.dark .coffee-card {
        background: rgba(var(--gray-light), 0.08);
        border: 1px solid rgba(var(--gray), 0.1);
    }
</style>
