---
import { Image } from 'astro:assets';
import awsIcon from '../assets/tech-icons/aws.png';
import terraformIcon from '../assets/tech-icons/terraform.png';
import dockerIcon from '../assets/tech-icons/docker.png';
import tsIcon from '../assets/tech-icons/ts.png';
import pythonIcon from '../assets/tech-icons/python.png';
import javaIcon from '../assets/tech-icons/java.png';
import kotlinIcon from '../assets/tech-icons/kotlin.png';
import n8nIcon from '../assets/tech-icons/n8n.png';
import claudeIcon from '../assets/tech-icons/claude.png';
import googleIcon from '../assets/tech-icons/google.png';

const technologies = [
  { name: 'technologies', src: null },
  { name: 'AWS', src: awsIcon.src },
  { name: 'Terraform', src: terraformIcon.src },
  { name: 'Docker', src: dockerIcon.src },
  { name: 'TypeScript', src: tsIcon.src },
  { name: 'Python', src: pythonIcon.src },
  { name: 'Java', src: javaIcon.src },
  { name: 'Kotlin', src: kotlinIcon.src },
  { name: 'N8N', src: n8nIcon.src },
  { name: 'Claude', src: claudeIcon.src },
  { name: 'GCP', src: googleIcon.src },
];
---

<span class="tech-swapper-container inline-flex relative overflow-hidden h-[1.5em] transition-[width] duration-700 ease-[cubic-bezier(0.76,0,0.24,1)] select-none">
  <span class="tech-reel flex flex-col transition-transform duration-700 ease-[cubic-bezier(0.76,0,0.24,1)]">
    {technologies.map((tech) => (
      <span class="tech-item flex items-center h-[1.5em] whitespace-nowrap w-max">
        {tech.src && <img src={tech.src} alt="" class="w-[0.9em] h-[0.9em] mr-[0.3em] object-contain" />}
        <strong class="text-black dark:text-white font-bold">{tech.name}</strong>
      </span>
    ))}
    {/* Duplicate first item for seamless loop */}
    <span class="tech-item flex items-center h-[1.5em] whitespace-nowrap w-max">
      <strong class="text-black dark:text-white font-bold">{technologies[0].name}</strong>
    </span>
  </span>
</span>

<style>
  .tech-swapper-container {
    vertical-align: 0em;
  }
  .tech-item {
    line-height: 1.5em;
  }
</style>

<script is:inline define:vars={{ techCount: technologies.length }}>
  function initTechSwapper() {
    document.querySelectorAll('.tech-swapper-container').forEach(container => {
      const reel = container.querySelector('.tech-reel');
      const items = reel.querySelectorAll('.tech-item');
      let currentIndex = 0;

      function updateWidth() {
        const currentItem = items[currentIndex];
        if (currentItem) {
          const width = currentItem.offsetWidth;
          container.style.width = `${width}px`;
        }
      }

      // Initial measurement
      updateWidth();

      function nextTech() {
        currentIndex++;
        
        // Sync transitions
        const transitionStyle = '0.7s cubic-bezier(0.76, 0, 0.24, 1)';
        reel.style.transition = `transform ${transitionStyle}`;
        container.style.transition = `width ${transitionStyle}`;
        
        reel.style.transform = `translateY(${currentIndex * -1.5}em)`;
        
        updateWidth();

        if (currentIndex === techCount) {
          setTimeout(() => {
            reel.style.transition = 'none';
            container.style.transition = 'none';
            currentIndex = 0;
            reel.style.transform = `translateY(0)`;
            updateWidth();
          }, 700);
        }
      }

      setInterval(nextTech, 3000);
      window.addEventListener('resize', updateWidth);
      
      if (document.fonts) {
        document.fonts.ready.then(updateWidth);
      }
    });
  }

  initTechSwapper();
</script>
